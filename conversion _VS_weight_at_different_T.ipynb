import numpy as np
from scipy.integrate import quad
import matplotlib.pyplot as plt

# Mole Fractions
y_CO = 0.15
y_H2O = 0.20
y_H2 = 0.55
y_CO2 = 0.05
y_CH4 = 0.03

# Operating conditions
F_A0 = 1515      # kmol/hr
X_final = 0.75   # target conversion
P = 50           # bar
rho_b = 1500     # kg/m3


def reactor_volume(T_C, X_target):
    T_K = T_C + 273.15

    # Convert kmol/hr → mol/min
    F_A0_mol = F_A0 * 1000 / 60

    # Partial pressures
    p_CO0 = P * y_CO
    p_H2O0 = P * y_H2O

    # Equilibrium constant
    Kp = np.exp((4577.8 / T_K) - 4.33)

    # Kinetic constant
    k = 1.85e-5 * np.exp(-1855.5 / (8.314 * T_K))

    def rate_function(X):
        p_CO = p_CO0 * (1 - X)
        p_H2O = p_H2O0 * (1 - X)

        p_CO2 = p_CO0 * (y_CO2 / y_CO) * X
        p_H2  = p_CO0 * (y_H2  / y_CO) * X

        beta = (p_CO2 * p_H2) / (p_CO * p_H2O * Kp)

        r = k * p_CO * p_H2O * (1 - beta)
        r = max(r, 1e-10)

        return F_A0_mol / r

    W_g, _ = quad(rate_function, 0, X_target)

    W_ton = W_g / 1_000_000
    V = W_g / rho_b / 1000

    return W_ton, V


def plot_multi_temperature_X_W():
    temperatures = [310, 340, 380, 410]
    X_values = np.linspace(0.01, X_final, 50)

    plt.figure(figsize=(8,6))

    all_W = []

    for T_C in temperatures:
        W_ton_values = []

        for X in X_values:
            W_ton, _ = reactor_volume(T_C, X)
            W_ton_values.append(W_ton)

        all_W.extend(W_ton_values)

        plt.plot(W_ton_values, X_values, linewidth=2, label=f"{T_C}°C")

    # Y‑axis zoom
    plt.ylim(0.65, 0.78)

    # X‑axis start from 50 tons
    plt.xlim(50, max(all_W) * 1.05)

    # ===== NEW: Dash line at y = 0.75 =====
    plt.axhline(y=0.75, color='black', linestyle='--', linewidth=1)

    plt.xlabel("Catalyst Weight W (ton)")
    plt.ylabel("Conversion X")
    plt.title("Multi-Temperature Conversion vs Catalyst Weight (X–W)")
    plt.grid(True)
    plt.legend(title="Temperature")
    plt.tight_layout()
    plt.show()


# Example
W, V = reactor_volume(310, X_final)
print("Catalyst weight (ton) =", format(W, '.6f'))
print("Reactor volume (m3) =", format(V, '.6f'))

# Plot
plot_multi_temperature_X_W()
